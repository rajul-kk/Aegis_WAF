# Copy this file to .env and fill in real values. Never commit .env itself.

# --- Groq (used for the actual answer-generation LLM in AegisGateway.chat()) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- NVIDIA NIM (used for Llama Guard classification + all 5 council agents) ---
# NVIDIA_API_KEY is used everywhere; NVIDIA_NIM_API_KEY only overrides it for
# the Llama Guard classifier specifically (config/actions.py) if you want a
# separate key/quota for that one call.
NVIDIA_API_KEY=
NVIDIA_NIM_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Council agent models (NVIDIA NIM model IDs)
LLAMA_MODEL=meta/llama-3.3-70b-instruct
LLAMA_MODEL_LIGHT=meta/llama-3.1-8b-instruct
ADVERSARIAL_MODEL=mistralai/mixtral-8x7b-instruct-v0.1
LLAMA_GUARD_MODEL=meta/llama-guard-3-8b

# --- Redis (session history persistence, core/session_store.py) ---
# Defaults to a local instance; docker-compose sets this to redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0
